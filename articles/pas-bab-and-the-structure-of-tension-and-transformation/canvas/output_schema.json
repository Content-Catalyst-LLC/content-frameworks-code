{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/pas-bab-and-the-structure-of-tension-and-transformation-canvas-output.schema.json",
  "title": "Catalyst Canvas Output Schema: PAS, BAB, and the Structure of Tension and Transformation",
  "description": "Output schema for Catalyst Canvas article-readiness audit results, UI cards, catalog records, and governance queues.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "generated_at",
    "results",
    "governance_queue",
    "canvas_cards"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "pas_bab_and_the_structure_of_tension_and_transformation_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "pas-bab-and-the-structure-of-tension-and-transformation"
    },
    "generated_at": {
      "type": "string"
    },
    "results": {
      "type": "array"
    },
    "governance_queue": {
      "type": "array"
    },
    "canvas_cards": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
