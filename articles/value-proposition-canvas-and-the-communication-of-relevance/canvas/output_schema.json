{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/value-proposition-canvas-and-the-communication-of-relevance-canvas-output.schema.json",
  "title": "Catalyst Canvas Output Schema: Value Proposition Canvas and the Communication of Relevance",
  "description": "Output schema for Catalyst Canvas article-readiness audit results, UI cards, catalog records, and governance queues.",
  "type": "object",
  "required": ["module", "article_slug", "generated_at", "results", "governance_queue", "canvas_cards"],
  "properties": {
    "module": { "type": "string", "const": "value_proposition_canvas_and_the_communication_of_relevance_canvas" },
