{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/sustainability-communication-canvas-output.schema.json",
  "title": "Sustainability Communication Catalyst Canvas Output Schema",
  "description": "Output schema for sustainability claim audit results Canvas cards catalog records and governance queues.",
  "type": "object",
  "required": ["module", "article_slug", "generated_at", "results", "governance_queue", "canvas_cards"],
  "properties": {
    "module": { "type": "string", "const": "sustainability_canvas" },
    "article_slug": { "type": "string", "const": "frameworks-for-sustainability-communication" },
    "generated_at": { "type": "string" },
    "results": { "type": "array" },
    "governance_queue": { "type": "array" },
    "canvas_cards": { "type": "array" }
  },
  "additionalProperties": true
}
