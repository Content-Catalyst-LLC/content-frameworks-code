{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/ansoff-matrix-canvas-output.schema.json",
  "title": "Ansoff Matrix Catalyst Canvas Output Schema",
  "description": "Output schema for Ansoff growth-option audit results, UI cards, catalog records, risk diagnostics, and governance queues.",
  "type": "object",
  "required": ["module", "article_slug", "generated_at", "results", "governance_queue", "canvas_cards"],
  "properties": {
    "module": { "type": "string", "const": "ansoff_canvas" },
    "article_slug": { "type": "string", "const": "ansoff-matrix-and-the-communication-of-growth-strategy" },
    "generated_at": { "type": "string" },
    "results": { "type": "array" },
    "governance_queue": { "type": "array" },
    "canvas_cards": { "type": "array" }
  },
  "additionalProperties": true
}
