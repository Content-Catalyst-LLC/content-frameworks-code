{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/ansoff-matrix-canvas-input.schema.json",
  "title": "Ansoff Matrix Catalyst Canvas Input Schema",
  "description": "Input schema for Ansoff growth-option classification, market status, product status, readiness, risk, evidence strength, expected value, and governance status.",
  "type": "object",
  "required": ["module", "article_slug", "options"],
  "properties": {
    "module": { "type": "string", "const": "ansoff_canvas" },
    "article_slug": { "type": "string", "const": "ansoff-matrix-and-the-communication-of-growth-strategy" },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "option",
          "growth_path",
          "market_status",
          "product_status",
          "description",
          "strategic_fit",
          "evidence_strength",
          "feasibility",
          "capability_readiness",
          "expected_value",
          "market_familiarity",
          "product_familiarity",
          "uncertainty",
          "claim_strength",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "option": { "type": "string", "minLength": 2 },
          "growth_path": {
            "type": "string",
            "enum": ["market penetration", "market development", "product development", "diversification", "unclear"]
          },
          "market_status": { "type": "string", "enum": ["existing", "new"] },
          "product_status": { "type": "string", "enum": ["existing", "new"] },
          "description": { "type": "string", "minLength": 5 },
          "strategic_fit": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "feasibility": { "type": "number", "minimum": 0, "maximum": 1 },
          "capability_readiness": { "type": "number", "minimum": 0, "maximum": 1 },
          "expected_value": { "type": "number", "minimum": 0, "maximum": 1 },
          "market_familiarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "product_familiarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "uncertainty": { "type": "number", "minimum": 0, "maximum": 1 },
          "claim_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
