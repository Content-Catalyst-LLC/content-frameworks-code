{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/storytelling-frameworks-for-transformation-and-action-canvas-input.schema.json",
  "title": "Catalyst Canvas Input Schema: Storytelling Frameworks for Transformation and Action",
  "description": "Input schema for Catalyst Canvas article-readiness records.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "records"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "storytelling_frameworks_for_transformation_and_action_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "storytelling-frameworks-for-transformation-and-action"
    },
    "records": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
