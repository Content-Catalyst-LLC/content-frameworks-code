{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/strategic-foresight-canvas-input.schema.json",
  "title": "Strategic Foresight and Scenario Thinking Catalyst Canvas Input Schema",
  "description": "Input schema for auditing strategic foresight items including driver clarity, uncertainty logic, scenario logic, assumption transparency, option relevance, indicator coverage, evidence strength, stakeholder visibility, importance, uncertainty, ownership, and governance status.",
  "type": "object",
  "required": ["module", "article_slug", "items"],
  "properties": {
    "module": { "type": "string", "const": "strategic_foresight_canvas" },
    "article_slug": { "type": "string", "const": "frameworks-for-strategic-foresight-and-scenario-thinking" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "item",
          "foresight_type",
          "description",
          "driver_clarity",
          "uncertainty_logic",
          "scenario_logic",
          "assumption_transparency",
          "option_relevance",
          "indicator_coverage",
          "evidence_strength",
          "stakeholder_visibility",
          "importance",
          "uncertainty",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "item": { "type": "string", "minLength": 2 },
          "foresight_type": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "driver_clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "uncertainty_logic": { "type": "number", "minimum": 0, "maximum": 1 },
          "scenario_logic": { "type": "number", "minimum": 0, "maximum": 1 },
          "assumption_transparency": { "type": "number", "minimum": 0, "maximum": 1 },
          "option_relevance": { "type": "number", "minimum": 0, "maximum": 1 },
          "indicator_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "stakeholder_visibility": { "type": "number", "minimum": 0, "maximum": 1 },
          "importance": { "type": "number", "minimum": 0, "maximum": 1 },
          "uncertainty": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
