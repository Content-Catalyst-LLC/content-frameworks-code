{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/strategic-foresight-canvas-output.schema.json",
  "title": "Strategic Foresight and Scenario Thinking Catalyst Canvas Output Schema",
  "description": "Output schema for strategic foresight audit results, Canvas cards, catalog records, and governance queues.",
  "type": "object",
  "required": ["module", "article_slug", "generated_at", "results", "governance_queue", "canvas_cards"],
  "properties": {
    "module": { "type": "string", "const": "strategic_foresight_canvas" },
    "article_slug": { "type": "string", "const": "frameworks-for-strategic-foresight-and-scenario-thinking" },
    "generated_at": { "type": "string" },
    "results": { "type": "array" },
    "governance_queue": { "type": "array" },
    "canvas_cards": { "type": "array" }
  },
  "additionalProperties": true
}
