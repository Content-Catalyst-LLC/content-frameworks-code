{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/jobs-to-be-done-and-the-problem-of-audience-need-canvas-output.schema.json",
  "title": "Catalyst Canvas Output Schema: Jobs to Be Done and the Problem of Audience Need",
  "description": "Output schema for Catalyst Canvas article-readiness audit results, UI cards, catalog records, and governance queues.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "generated_at",
    "results",
    "governance_queue",
    "canvas_cards"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "jobs_to_be_done_and_the_problem_of_audience_need_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "jobs-to-be-done-and-the-problem-of-audience-need"
    },
    "generated_at": {
      "type": "string"
    },
    "results": {
      "type": "array"
    },
    "governance_queue": {
      "type": "array"
    },
    "canvas_cards": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
