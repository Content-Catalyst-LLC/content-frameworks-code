{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/public-reasoning-canvas-output.schema.json",
  "title": "Public Reasoning and Framework Design Catalyst Canvas Output Schema",
  "description": "Output schema for public reasoning audit results, Canvas cards, catalog records, and governance queues.",
  "type": "object",
  "required": ["module", "article_slug", "generated_at", "results", "governance_queue", "canvas_cards"],
  "properties": {
    "module": { "type": "string", "const": "public_reasoning_canvas" },
    "article_slug": { "type": "string", "const": "public-reasoning-and-framework-design" },
    "generated_at": { "type": "string" },
    "results": { "type": "array" },
    "governance_queue": { "type": "array" },
    "canvas_cards": { "type": "array" }
  },
  "additionalProperties": true
}
