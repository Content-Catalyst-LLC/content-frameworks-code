{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/content-audits-and-framework-governance-canvas-input.schema.json",
  "title": "Catalyst Canvas Input Schema: Content Audits and Framework Governance",
  "description": "Input schema for Catalyst Canvas article-readiness records.",
  "type": "object",
  "required": ["module", "article_slug", "records"],
  "properties": {
    "module": {
      "type": "string",
      "const": "content_audits_and_framework_governance_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "content-audits-and-framework-governance"
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "record_id",
          "article_slug",
          "article_title",
          "module_kind",
          "canvas_dimension",
          "description",
          "content_value",
          "audience_value",
          "evidence_strength",
          "repository_support",
          "governance_need",
          "ethical_risk",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "record_id": { "type": "string", "minLength": 2 },
          "article_slug": { "type": "string", "const": "content-audits-and-framework-governance" },
          "article_title": { "type": "string", "minLength": 2 },
          "module_kind": { "type": "string", "minLength": 2 },
          "canvas_dimension": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "content_value": { "type": "number", "minimum": 0, "maximum": 1 },
          "audience_value": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "repository_support": { "type": "number", "minimum": 0, "maximum": 1 },
          "governance_need": { "type": "number", "minimum": 0, "maximum": 1 },
          "ethical_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
