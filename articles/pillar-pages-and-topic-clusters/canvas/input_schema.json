{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/pillar-pages-and-topic-clusters-canvas-input.schema.json",
  "title": "Catalyst Canvas Input Schema: Pillar Pages and Topic Clusters",
  "description": "Input schema for Catalyst Canvas article-readiness records.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "records"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "pillar_pages_and_topic_clusters_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "pillar-pages-and-topic-clusters"
    },
    "records": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
