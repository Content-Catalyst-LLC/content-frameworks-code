{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/5w1h-and-the-architecture-of-explanatory-completeness-canvas-output.schema.json",
  "title": "Catalyst Canvas Output Schema: 5W1H and the Architecture of Explanatory Completeness",
  "description": "Output schema for Catalyst Canvas article-readiness audit results, UI cards, catalog records, and governance queues.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "generated_at",
    "results",
    "governance_queue",
    "canvas_cards"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "5w1h_and_the_architecture_of_explanatory_completeness_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "5w1h-and-the-architecture-of-explanatory-completeness"
    },
    "generated_at": {
      "type": "string"
    },
    "results": {
      "type": "array"
    },
    "governance_queue": {
      "type": "array"
    },
    "canvas_cards": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
