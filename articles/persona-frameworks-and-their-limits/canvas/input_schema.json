{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/persona-frameworks-canvas-input.schema.json",
  "title": "Persona Frameworks Catalyst Canvas Input Schema",
  "description": "Input schema for persona evidence readiness segment alignment content fit stereotype risk exclusion risk weak evidence risk overgeneralization risk and governance status.",
  "type": "object",
  "required": ["module", "article_slug", "personas"],
  "properties": {
    "module": { "type": "string", "const": "persona_canvas" },
    "article_slug": { "type": "string", "const": "persona-frameworks-and-their-limits" },
    "personas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "persona",
          "segment",
          "description",
          "content_pathway",
          "evidence_strength",
          "specificity",
          "content_fit",
          "segment_alignment",
          "governance_readiness",
          "stereotype_risk",
          "exclusion_risk",
          "weak_evidence_risk",
          "overgeneralization_risk",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "persona": { "type": "string", "minLength": 2 },
          "segment": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "content_pathway": { "type": "string", "minLength": 2 },
          "evidence_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "specificity": { "type": "number", "minimum": 0, "maximum": 1 },
          "content_fit": { "type": "number", "minimum": 0, "maximum": 1 },
          "segment_alignment": { "type": "number", "minimum": 0, "maximum": 1 },
          "governance_readiness": { "type": "number", "minimum": 0, "maximum": 1 },
          "stereotype_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "exclusion_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "weak_evidence_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "overgeneralization_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
