{
  "module": "five_forces_canvas",
  "version": "1.0.0",
  "article_slug": "porters-five-forces-and-competitive-framing",
  "article_title": "Porter’s Five Forces and Competitive Framing",
  "series": "Content Frameworks",
  "repository_path": "articles/porters-five-forces-and-competitive-framing/",
  "entrypoint": "python -m five_forces_canvas.cli",
  "default_input": "data/five_forces_records.csv",
  "input_schema": "canvas/input_schema.json",
  "output_schema": "canvas/output_schema.json",
  "generated_outputs": {
    "audit_table": "outputs/tables/five_forces_canvas_audit.csv",
    "catalog": "outputs/json/catalog.json",
    "canvas_cards": "canvas/canvas_cards.json",
    "governance_queue": "canvas/governance_queue.json",
    "governance_markdown": "outputs/markdown/governance_queue.md",
    "full_export": "outputs/json/five_forces_canvas_export.json"
  },
  "metrics": [
    "readiness_score",
    "weighted_priority",
    "evidence_gap",
    "governance_priority",
    "review_priority"
  ],
  "ui_cards": [
    {
      "type": "five_forces_record_card",
      "source": "canvas/canvas_cards.json",
      "recommended_view": "force_grid"
    },
    {
      "type": "five_forces_governance_queue",
      "source": "canvas/governance_queue.json",
      "recommended_view": "review_table"
    }
  ],
  "governance": {
    "owner": "Content Catalyst LLC",
    "review_cycle": "quarterly",
    "status_values": ["active", "review", "revise", "archive"],
    "risk_flags": [
      "evidence_gap",
      "unclear_market_boundary",
      "weak_specificity",
      "high_uncertainty",
      "low_actionability",
      "unsupported_competitive_claim"
    ]
  }
}
