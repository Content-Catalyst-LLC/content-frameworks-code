{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/five-forces-canvas-input.schema.json",
  "title": "Porter Five Forces Catalyst Canvas Input Schema",
  "description": "Input schema for competitive force analysis including market boundary intensity evidence strength uncertainty strategic relevance actionability claim strength and governance status.",
  "type": "object",
  "required": ["module", "article_slug", "records"],
  "properties": {
    "module": { "type": "string", "const": "five_forces_canvas" },
    "article_slug": { "type": "string", "const": "porters-five-forces-and-competitive-framing" },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "force",
          "market_boundary",
          "description",
          "intensity",
          "evidence_strength",
          "uncertainty",
          "strategic_relevance",
          "actionability",
          "claim_strength",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "force": {
            "type": "string",
            "enum": ["rivalry", "new entrants", "substitutes", "supplier power", "buyer power", "competition"]
          },
          "market_boundary": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "intensity": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "uncertainty": { "type": "number", "minimum": 0, "maximum": 1 },
          "strategic_relevance": { "type": "number", "minimum": 0, "maximum": 1 },
          "actionability": { "type": "number", "minimum": 0, "maximum": 1 },
          "claim_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
