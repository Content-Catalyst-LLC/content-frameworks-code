{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/knowledge-scaling-canvas-output.schema.json",
  "title": "Scaling Knowledge Through Frameworks Catalyst Canvas Output Schema",
  "description": "Output schema for knowledge scaling audit results, Canvas cards, catalog records, and governance queues.",
  "type": "object",
  "required": ["module", "article_slug", "generated_at", "results", "governance_queue", "canvas_cards"],
  "properties": {
    "module": { "type": "string", "const": "knowledge_scaling_canvas" },
    "article_slug": { "type": "string", "const": "scaling-knowledge-through-frameworks" },
    "generated_at": { "type": "string" },
    "results": { "type": "array" },
    "governance_queue": { "type": "array" },
    "canvas_cards": { "type": "array" }
  },
  "additionalProperties": true
}
