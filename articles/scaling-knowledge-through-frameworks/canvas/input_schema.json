{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/knowledge-scaling-canvas-input.schema.json",
  "title": "Scaling Knowledge Through Frameworks Catalyst Canvas Input Schema",
  "description": "Input schema for auditing knowledge scaling assets including modularity, taxonomy quality, metadata completeness, link coverage, evidence alignment, reuse readiness, governance maturity, platform readiness, audience pathway clarity, dependency complexity, ownership, and governance status.",
  "type": "object",
  "required": ["module", "article_slug", "items"],
  "properties": {
    "module": { "type": "string", "const": "knowledge_scaling_canvas" },
    "article_slug": { "type": "string", "const": "scaling-knowledge-through-frameworks" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "item",
          "asset_type",
          "description",
          "modularity",
          "taxonomy_quality",
          "metadata_completeness",
          "link_coverage",
          "evidence_alignment",
          "reuse_readiness",
          "governance_maturity",
          "platform_readiness",
          "audience_pathway_clarity",
          "dependency_complexity",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "item": { "type": "string", "minLength": 2 },
          "asset_type": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "modularity": { "type": "number", "minimum": 0, "maximum": 1 },
          "taxonomy_quality": { "type": "number", "minimum": 0, "maximum": 1 },
          "metadata_completeness": { "type": "number", "minimum": 0, "maximum": 1 },
          "link_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_alignment": { "type": "number", "minimum": 0, "maximum": 1 },
          "reuse_readiness": { "type": "number", "minimum": 0, "maximum": 1 },
          "governance_maturity": { "type": "number", "minimum": 0, "maximum": 1 },
          "platform_readiness": { "type": "number", "minimum": 0, "maximum": 1 },
          "audience_pathway_clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "dependency_complexity": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
