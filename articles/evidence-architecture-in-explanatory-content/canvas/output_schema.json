{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/evidence-architecture-in-explanatory-content-canvas-output.schema.json",
  "title": "Catalyst Canvas Output Schema: Evidence Architecture in Explanatory Content",
  "description": "Output schema for Catalyst Canvas article-readiness audit results, UI cards, catalog records, and governance queues.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "generated_at",
    "results",
    "governance_queue",
    "canvas_cards"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "evidence_architecture_in_explanatory_content_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "evidence-architecture-in-explanatory-content"
    },
    "generated_at": {
      "type": "string"
    },
    "results": {
      "type": "array"
    },
    "governance_queue": {
      "type": "array"
    },
    "canvas_cards": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
