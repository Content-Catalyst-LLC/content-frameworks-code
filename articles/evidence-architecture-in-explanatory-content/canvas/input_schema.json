{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/evidence-architecture-in-explanatory-content-canvas-input.schema.json",
  "title": "Catalyst Canvas Input Schema: Evidence Architecture in Explanatory Content",
  "description": "Input schema for Catalyst Canvas article-readiness records.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "records"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "evidence_architecture_in_explanatory_content_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "evidence-architecture-in-explanatory-content"
    },
    "records": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
