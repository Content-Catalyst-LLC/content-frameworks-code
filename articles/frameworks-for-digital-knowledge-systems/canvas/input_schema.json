{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/frameworks-for-digital-knowledge-systems-canvas-input.schema.json",
  "title": "Catalyst Canvas Input Schema: Frameworks for Digital Knowledge Systems",
  "description": "Input schema for Catalyst Canvas article-readiness records.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "records"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "frameworks_for_digital_knowledge_systems_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "frameworks-for-digital-knowledge-systems"
    },
    "records": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
