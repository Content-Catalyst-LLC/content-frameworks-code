{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/bcg-matrix-canvas-output.schema.json",
  "title": "BCG Matrix Catalyst Canvas Output Schema",
  "description": "Output schema for BCG portfolio classification results Canvas cards catalog records and governance queues.",
  "type": "object",
  "required": ["module", "article_slug", "generated_at", "results", "governance_queue", "canvas_cards"],
  "properties": {
    "module": { "type": "string", "const": "bcg_canvas" },
    "article_slug": { "type": "string", "const": "bcg-matrix-and-portfolio-communication" },
    "generated_at": { "type": "string" },
    "results": { "type": "array" },
    "governance_queue": { "type": "array" },
    "canvas_cards": { "type": "array" }
  },
  "additionalProperties": true
}
