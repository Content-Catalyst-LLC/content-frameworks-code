{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/bcg-matrix-canvas-input.schema.json",
  "title": "BCG Matrix Catalyst Canvas Input Schema",
  "description": "Input schema for BCG portfolio analysis including portfolio area growth score relative share score evidence strength strategic fit maintenance burden claim strength and governance status.",
  "type": "object",
  "required": ["module", "article_slug", "items"],
  "properties": {
    "module": { "type": "string", "const": "bcg_canvas" },
    "article_slug": { "type": "string", "const": "bcg-matrix-and-portfolio-communication" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "item",
          "portfolio_area",
          "description",
          "growth_score",
          "relative_share_score",
          "evidence_strength",
          "strategic_fit",
          "maintenance_burden",
          "claim_strength",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "item": { "type": "string", "minLength": 2 },
          "portfolio_area": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "growth_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "relative_share_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "strategic_fit": { "type": "number", "minimum": 0, "maximum": 1 },
          "maintenance_burden": { "type": "number", "minimum": 0, "maximum": 1 },
          "claim_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
