{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/ai-assisted-framework-design-canvas-input.schema.json",
  "title": "AI-Assisted Framework Design Catalyst Canvas Input Schema",
  "description": "Input schema for auditing AI-assisted framework design including conceptual clarity, evidence grounding, metadata consistency, human review strength, bias review, governance maturity, platform readiness, drift control, unsupported-claim risk, generic-structure risk, output validation, audience impact, ownership, and governance status.",
  "type": "object",
  "required": ["module", "article_slug", "items"],
  "properties": {
    "module": { "type": "string", "const": "ai_assisted_framework_design_canvas" },
    "article_slug": { "type": "string", "const": "ai-assisted-framework-design" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "item",
          "item_type",
          "description",
          "conceptual_clarity",
          "evidence_grounding",
          "metadata_consistency",
          "human_review_strength",
          "bias_review",
          "governance_maturity",
          "platform_readiness",
          "drift_control",
          "unsupported_claim_risk",
          "generic_structure_risk",
          "output_validation",
          "audience_impact",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "item": { "type": "string", "minLength": 2 },
          "item_type": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "conceptual_clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_grounding": { "type": "number", "minimum": 0, "maximum": 1 },
          "metadata_consistency": { "type": "number", "minimum": 0, "maximum": 1 },
          "human_review_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "bias_review": { "type": "number", "minimum": 0, "maximum": 1 },
          "governance_maturity": { "type": "number", "minimum": 0, "maximum": 1 },
          "platform_readiness": { "type": "number", "minimum": 0, "maximum": 1 },
          "drift_control": { "type": "number", "minimum": 0, "maximum": 1 },
          "unsupported_claim_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "generic_structure_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "output_validation": { "type": "number", "minimum": 0, "maximum": 1 },
          "audience_impact": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
