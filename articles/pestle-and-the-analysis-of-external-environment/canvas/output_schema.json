{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/pestle-analysis-canvas-output.schema.json",
  "title": "PESTLE Analysis Catalyst Canvas Output Schema",
  "description": "Output schema for PESTLE priority audit results UI cards catalog records monitoring queue and governance queue.",
  "type": "object",
  "required": ["module", "article_slug", "generated_at", "results", "governance_queue", "canvas_cards"],
  "properties": {
    "module": { "type": "string", "const": "pestle_canvas" },
    "article_slug": { "type": "string", "const": "pestle-and-the-analysis-of-external-environment" },
    "generated_at": { "type": "string" },
    "results": { "type": "array" },
    "governance_queue": { "type": "array" },
    "canvas_cards": { "type": "array" }
  },
  "additionalProperties": true
}
