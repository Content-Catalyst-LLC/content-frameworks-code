{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/pestle-analysis-canvas-input.schema.json",
  "title": "PESTLE Analysis Catalyst Canvas Input Schema",
  "description": "Input schema for PESTLE external-factor category classification signal type impact urgency evidence strength uncertainty strategic relevance actionability claim strength and governance status.",
  "type": "object",
  "required": ["module", "article_slug", "factors"],
  "properties": {
    "module": { "type": "string", "const": "pestle_canvas" },
    "article_slug": { "type": "string", "const": "pestle-and-the-analysis-of-external-environment" },
    "factors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "factor",
          "category",
          "signal_type",
          "description",
          "impact",
          "urgency",
          "evidence_strength",
          "uncertainty",
          "strategic_relevance",
          "actionability",
          "claim_strength",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "factor": { "type": "string", "minLength": 2 },
          "category": {
            "type": "string",
            "enum": ["political", "economic", "social", "technological", "legal", "environmental"]
          },
          "signal_type": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "impact": { "type": "number", "minimum": 0, "maximum": 1 },
          "urgency": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "uncertainty": { "type": "number", "minimum": 0, "maximum": 1 },
          "strategic_relevance": { "type": "number", "minimum": 0, "maximum": 1 },
          "actionability": { "type": "number", "minimum": 0, "maximum": 1 },
          "claim_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
