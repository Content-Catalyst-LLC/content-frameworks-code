{
  "module": "framework_limits_canvas",
  "version": "1.0.0",
  "article_slug": "the-limits-of-framework-thinking",
  "article_title": "The Limits of Framework Thinking",
  "series": "Content Frameworks",
  "repository_path": "articles/the-limits-of-framework-thinking/",
  "entrypoint": "python -m framework_limits_canvas.cli",
  "default_input": "data/framework_limits_items.csv",
  "input_schema": "canvas/input_schema.json",
  "output_schema": "canvas/output_schema.json",
  "generated_outputs": {
    "audit_table": "outputs/tables/framework_limits_canvas_audit.csv",
    "catalog": "outputs/json/catalog.json",
    "canvas_cards": "canvas/canvas_cards.json",
    "governance_queue": "canvas/governance_queue.json",
    "governance_markdown": "outputs/markdown/governance_queue.md",
    "full_export": "outputs/json/framework_limits_canvas_export.json"
  },
  "metrics": [
    "usefulness_score",
    "distortion_risk",
    "review_priority_score",
    "review_priority"
  ],
  "ui_cards": [
    {
      "type": "framework_limits_item_card",
      "source": "canvas/canvas_cards.json",
      "recommended_view": "framework_limits_grid"
    },
    {
      "type": "framework_limits_governance_queue",
      "source": "canvas/governance_queue.json",
      "recommended_view": "review_table"
    }
  ],
  "governance": {
    "owner": "Content Catalyst LLC",
    "review_cycle": "quarterly",
    "status_values": ["active", "review", "revise", "archive"],
    "risk_flags": [
      "weak_clarity",
      "weak_fit",
      "weak_evidence_alignment",
      "weak_assumption_transparency",
      "weak_governance_readiness",
      "high_oversimplification_risk",
      "high_false_precision_risk",
      "high_context_loss",
      "high_audience_burden",
      "high_value_opacity",
      "high_distortion_risk",
      "review_priority"
    ]
  }
}
