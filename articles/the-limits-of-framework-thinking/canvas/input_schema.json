{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/framework-limits-canvas-input.schema.json",
  "title": "The Limits of Framework Thinking Catalyst Canvas Input Schema",
  "description": "Input schema for auditing framework limits including clarity, fit, evidence alignment, assumption transparency, governance readiness, oversimplification risk, false precision risk, context loss, audience burden, value opacity, ownership, and governance status.",
  "type": "object",
  "required": ["module", "article_slug", "items"],
  "properties": {
    "module": { "type": "string", "const": "framework_limits_canvas" },
    "article_slug": { "type": "string", "const": "the-limits-of-framework-thinking" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "item",
          "framework_type",
          "description",
          "clarity",
          "fit",
          "evidence_alignment",
          "assumption_transparency",
          "governance_readiness",
          "oversimplification_risk",
          "false_precision_risk",
          "context_loss",
          "audience_burden",
          "value_opacity",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "item": { "type": "string", "minLength": 2 },
          "framework_type": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "fit": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_alignment": { "type": "number", "minimum": 0, "maximum": 1 },
          "assumption_transparency": { "type": "number", "minimum": 0, "maximum": 1 },
          "governance_readiness": { "type": "number", "minimum": 0, "maximum": 1 },
          "oversimplification_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "false_precision_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "context_loss": { "type": "number", "minimum": 0, "maximum": 1 },
          "audience_burden": { "type": "number", "minimum": 0, "maximum": 1 },
          "value_opacity": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
