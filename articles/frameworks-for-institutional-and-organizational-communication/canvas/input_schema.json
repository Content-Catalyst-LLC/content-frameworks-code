{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/institutional-communication-canvas-input.schema.json",
  "title": "Institutional and Organizational Communication Catalyst Canvas Input Schema",
  "description": "Input schema for auditing institutional communication clarity authority coverage evidence strength stakeholder visibility feedback quality channel fit cultural alignment governance coverage ambiguity claim strength and governance status.",
  "type": "object",
  "required": ["module", "article_slug", "items"],
  "properties": {
    "module": { "type": "string", "const": "institutional_communication_canvas" },
    "article_slug": { "type": "string", "const": "frameworks-for-institutional-and-organizational-communication" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "item",
          "communication_type",
          "description",
          "clarity",
          "authority_coverage",
          "evidence_strength",
          "stakeholder_visibility",
          "feedback_quality",
          "channel_fit",
          "cultural_alignment",
          "governance_coverage",
          "ambiguity",
          "claim_strength",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "item": { "type": "string", "minLength": 2 },
          "communication_type": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "authority_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "stakeholder_visibility": { "type": "number", "minimum": 0, "maximum": 1 },
          "feedback_quality": { "type": "number", "minimum": 0, "maximum": 1 },
          "channel_fit": { "type": "number", "minimum": 0, "maximum": 1 },
          "cultural_alignment": { "type": "number", "minimum": 0, "maximum": 1 },
          "governance_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
          "ambiguity": { "type": "number", "minimum": 0, "maximum": 1 },
          "claim_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
