{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/framework-drift-canvas-input.schema.json",
  "title": "Framework Drift and Conceptual Decay Catalyst Canvas Input Schema",
  "description": "Input schema for auditing framework drift and conceptual decay including definition consistency, boundary clarity, evidence currency, metadata consistency, link health, governance maturity, reuse pressure, stale evidence risk, dependency complexity, platform alignment, audience impact, ownership, and governance status.",
  "type": "object",
  "required": ["module", "article_slug", "items"],
  "properties": {
    "module": { "type": "string", "const": "framework_drift_canvas" },
    "article_slug": { "type": "string", "const": "framework-drift-and-conceptual-decay" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "item",
          "item_type",
          "description",
          "definition_consistency",
          "boundary_clarity",
          "evidence_currency",
          "metadata_consistency",
          "link_health",
          "governance_maturity",
          "reuse_pressure",
          "stale_evidence_risk",
          "dependency_complexity",
          "platform_alignment",
          "audience_impact",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "item": { "type": "string", "minLength": 2 },
          "item_type": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "definition_consistency": { "type": "number", "minimum": 0, "maximum": 1 },
          "boundary_clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_currency": { "type": "number", "minimum": 0, "maximum": 1 },
          "metadata_consistency": { "type": "number", "minimum": 0, "maximum": 1 },
          "link_health": { "type": "number", "minimum": 0, "maximum": 1 },
          "governance_maturity": { "type": "number", "minimum": 0, "maximum": 1 },
          "reuse_pressure": { "type": "number", "minimum": 0, "maximum": 1 },
          "stale_evidence_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "dependency_complexity": { "type": "number", "minimum": 0, "maximum": 1 },
          "platform_alignment": { "type": "number", "minimum": 0, "maximum": 1 },
          "audience_impact": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
