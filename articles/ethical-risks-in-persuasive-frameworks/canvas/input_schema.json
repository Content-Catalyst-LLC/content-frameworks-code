{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/ethical-risks-in-persuasive-frameworks-canvas-input.schema.json",
  "title": "Catalyst Canvas Input Schema: Ethical Risks in Persuasive Frameworks",
  "description": "Input schema for Catalyst Canvas article-readiness records.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "records"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "ethical_risks_in_persuasive_frameworks_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "ethical-risks-in-persuasive-frameworks"
    },
    "records": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
