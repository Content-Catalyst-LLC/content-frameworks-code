{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/curriculum-pathways-and-framework-design-canvas-input.schema.json",
  "title": "Catalyst Canvas Input Schema: Curriculum Pathways and Framework Design",
  "description": "Input schema for Catalyst Canvas article-readiness records.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "records"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "curriculum_pathways_and_framework_design_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "curriculum-pathways-and-framework-design"
    },
    "records": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
