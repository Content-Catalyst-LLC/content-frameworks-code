{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/internal-linking-as-framework-infrastructure-canvas-input.schema.json",
  "title": "Catalyst Canvas Input Schema: Internal Linking as Framework Infrastructure",
  "description": "Input schema for Catalyst Canvas article-readiness records.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "records"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "internal_linking_as_framework_infrastructure_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "internal-linking-as-framework-infrastructure"
    },
    "records": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
