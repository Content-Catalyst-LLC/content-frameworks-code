{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/systems-explanation-canvas-input.schema.json",
  "title": "Systems Explanation Catalyst Canvas Input Schema",
  "description": "Input schema for auditing systems explanation items including boundary clarity, actor coverage, relationship clarity, feedback visibility, delay visibility, stock-flow clarity, stakeholder visibility, evidence strength, leverage readiness, ownership, and governance status.",
  "type": "object",
  "required": ["module", "article_slug", "items"],
  "properties": {
    "module": { "type": "string", "const": "systems_explanation_canvas" },
    "article_slug": { "type": "string", "const": "systems-explanation-frameworks" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "item",
          "explanation_type",
          "description",
          "boundary_clarity",
          "actor_coverage",
          "relationship_clarity",
          "feedback_visibility",
          "delay_visibility",
          "stock_flow_clarity",
          "stakeholder_visibility",
          "evidence_strength",
          "leverage_readiness",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "item": { "type": "string", "minLength": 2 },
          "explanation_type": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "boundary_clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "actor_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
          "relationship_clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "feedback_visibility": { "type": "number", "minimum": 0, "maximum": 1 },
          "delay_visibility": { "type": "number", "minimum": 0, "maximum": 1 },
          "stock_flow_clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "stakeholder_visibility": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "leverage_readiness": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
