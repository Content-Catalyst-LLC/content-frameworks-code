{
  "module": "systems_explanation_canvas",
  "version": "1.0.0",
  "article_slug": "systems-explanation-frameworks",
  "article_title": "Systems Explanation Frameworks",
  "series": "Content Frameworks",
  "repository_path": "articles/systems-explanation-frameworks/",
  "entrypoint": "python -m systems_explanation_canvas.cli",
  "default_input": "data/systems_explanation_items.csv",
  "input_schema": "canvas/input_schema.json",
  "output_schema": "canvas/output_schema.json",
  "generated_outputs": {
    "audit_table": "outputs/tables/systems_explanation_canvas_audit.csv",
    "catalog": "outputs/json/catalog.json",
    "canvas_cards": "canvas/canvas_cards.json",
    "governance_queue": "canvas/governance_queue.json",
    "governance_markdown": "outputs/markdown/governance_queue.md",
    "full_export": "outputs/json/systems_explanation_canvas_export.json"
  },
  "metrics": [
    "quality_score",
    "systems_ambiguity",
    "review_priority_score",
    "review_priority"
  ],
  "ui_cards": [
    {
      "type": "systems_explanation_item_card",
      "source": "canvas/canvas_cards.json",
      "recommended_view": "systems_governance_grid"
    },
    {
      "type": "systems_explanation_governance_queue",
      "source": "canvas/governance_queue.json",
      "recommended_view": "review_table"
    }
  ],
  "governance": {
    "owner": "Content Catalyst LLC",
    "review_cycle": "quarterly",
    "status_values": ["active", "review", "revise", "archive"],
    "risk_flags": [
      "weak_boundary_clarity",
      "weak_actor_coverage",
      "weak_relationship_clarity",
      "weak_feedback_visibility",
      "weak_delay_visibility",
      "weak_stock_flow_clarity",
      "weak_stakeholder_visibility",
      "weak_evidence_strength",
      "weak_leverage_readiness",
      "high_systems_ambiguity",
      "review_priority"
    ]
  }
}
