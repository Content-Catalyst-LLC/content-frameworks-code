{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/technology-science-communication-canvas-input.schema.json",
  "title": "Technology and Scientific Communication Catalyst Canvas Input Schema",
  "description": "Input schema for auditing technical and scientific communication claims including claim clarity evidence strength method transparency uncertainty disclosure audience fit risk visibility stakeholder visibility promotional intensity claim breadth and governance status.",
  "type": "object",
  "required": ["module", "article_slug", "items"],
  "properties": {
    "module": { "type": "string", "const": "technology_science_canvas" },
    "article_slug": { "type": "string", "const": "frameworks-for-technology-and-scientific-communication" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "item",
          "communication_type",
          "description",
          "claim_clarity",
          "evidence_strength",
          "method_transparency",
          "uncertainty_disclosure",
          "audience_fit",
          "risk_visibility",
          "stakeholder_visibility",
          "promotional_intensity",
          "claim_breadth",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "item": { "type": "string", "minLength": 2 },
          "communication_type": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "claim_clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "method_transparency": { "type": "number", "minimum": 0, "maximum": 1 },
          "uncertainty_disclosure": { "type": "number", "minimum": 0, "maximum": 1 },
          "audience_fit": { "type": "number", "minimum": 0, "maximum": 1 },
          "risk_visibility": { "type": "number", "minimum": 0, "maximum": 1 },
          "stakeholder_visibility": { "type": "number", "minimum": 0, "maximum": 1 },
          "promotional_intensity": { "type": "number", "minimum": 0, "maximum": 1 },
          "claim_breadth": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
