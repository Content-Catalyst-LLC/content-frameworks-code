{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/technology-science-communication-canvas-output.schema.json",
  "title": "Technology and Scientific Communication Catalyst Canvas Output Schema",
  "description": "Output schema for technology and scientific communication audit results Canvas cards catalog records and governance queues.",
  "type": "object",
  "required": ["module", "article_slug", "generated_at", "results", "governance_queue", "canvas_cards"],
  "properties": {
    "module": { "type": "string", "const": "technology_science_canvas" },
    "article_slug": { "type": "string", "const": "frameworks-for-technology-and-scientific-communication" },
    "generated_at": { "type": "string" },
    "results": { "type": "array" },
    "governance_queue": { "type": "array" },
    "canvas_cards": { "type": "array" }
  },
  "additionalProperties": true
}
