{
  "module": "positioning_canvas",
  "version": "1.0.0",
  "article_slug": "positioning-frameworks-for-complex-ideas",
  "article_title": "Positioning Frameworks for Complex Ideas",
  "series": "Content Frameworks",
  "repository_path": "articles/positioning-frameworks-for-complex-ideas/",
  "entrypoint": "python -m positioning_canvas.cli",
  "default_input": "data/positioning_records.csv",
  "input_schema": "canvas/input_schema.json",
  "output_schema": "canvas/output_schema.json",
  "generated_outputs": {
    "audit_table": "outputs/tables/positioning_canvas_audit.csv",
    "catalog": "outputs/json/catalog.json",
    "canvas_cards": "canvas/canvas_cards.json",
    "governance_queue": "canvas/governance_queue.json",
    "governance_markdown": "outputs/markdown/governance_queue.md",
    "full_export": "outputs/json/positioning_canvas_export.json"
  },
  "metrics": [
    "readiness_score",
    "weighted_readiness",
    "evidence_gap",
    "drift_risk",
    "ethical_risk",
    "review_priority"
  ],
  "ui_cards": [
    {
      "type": "positioning_record_card",
      "source": "canvas/canvas_cards.json",
      "recommended_view": "card_grid"
    },
    {
      "type": "positioning_governance_queue",
      "source": "canvas/governance_queue.json",
      "recommended_view": "review_table"
    }
  ],
  "governance": {
    "owner": "Content Catalyst LLC",
    "review_cycle": "quarterly",
    "status_values": ["active", "review", "revise", "archive"],
    "risk_flags": ["weak_category_frame", "evidence_gap", "boundary_gap", "drift_risk", "ethical_risk"]
  }
}
