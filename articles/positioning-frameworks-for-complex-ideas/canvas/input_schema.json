{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/positioning-frameworks-canvas-input.schema.json",
  "title": "Positioning Frameworks Catalyst Canvas Input Schema",
  "description": "Input schema for category framing audience relevance differentiation evidence boundary language ethical risk drift risk and governance readiness records.",
  "type": "object",
  "required": ["module", "article_slug", "records"],
  "properties": {
    "module": { "type": "string", "const": "positioning_canvas" },
    "article_slug": { "type": "string", "const": "positioning-frameworks-for-complex-ideas" },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "idea",
          "description",
          "category_frame",
          "audience_pathway",
          "category_clarity",
          "audience_relevance",
          "differentiation",
          "evidence_strength",
          "governance_readiness",
          "boundary_clarity",
          "ethical_risk",
          "drift_risk",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "idea": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "category_frame": { "type": "string", "minLength": 2 },
          "audience_pathway": { "type": "string", "minLength": 2 },
          "category_clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "audience_relevance": { "type": "number", "minimum": 0, "maximum": 1 },
          "differentiation": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "governance_readiness": { "type": "number", "minimum": 0, "maximum": 1 },
          "boundary_clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "ethical_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "drift_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
