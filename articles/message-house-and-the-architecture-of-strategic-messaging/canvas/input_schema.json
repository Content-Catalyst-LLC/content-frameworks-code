{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/message-house-canvas-input.schema.json",
  "title": "Message House Catalyst Canvas Input Schema",
  "description": "Input schema for message pillars proof points governance status evidence strength and strategic messaging readiness.",
  "type": "object",
  "required": ["module", "article_slug", "pillars"],
  "properties": {
    "module": { "type": "string", "const": "message_house_canvas" },
    "article_slug": { "type": "string", "const": "message-house-and-the-architecture-of-strategic-messaging" },
    "pillars": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "pillar",
          "description",
          "core_alignment",
          "audience_relevance",
          "evidence_strength",
          "differentiation",
          "governance_readiness",
          "ethical_risk",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "pillar": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "core_alignment": { "type": "number", "minimum": 0, "maximum": 1 },
          "audience_relevance": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "differentiation": { "type": "number", "minimum": 0, "maximum": 1 },
          "governance_readiness": { "type": "number", "minimum": 0, "maximum": 1 },
          "ethical_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
