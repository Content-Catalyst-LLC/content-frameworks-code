{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/framework-composition-canvas-input.schema.json",
  "title": "Framework Composition Catalyst Canvas Input Schema",
  "description": "Input schema for auditing framework composition items including purpose fit, role clarity, boundary clarity, sequence clarity, translation quality, evidence alignment, governance readiness, audience burden, conflict risk, ownership, and governance status.",
  "type": "object",
  "required": ["module", "article_slug", "items"],
  "properties": {
    "module": { "type": "string", "const": "framework_composition_canvas" },
    "article_slug": { "type": "string", "const": "framework-composition-how-to-combine-models-without-confusion" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "item",
          "composition_type",
          "description",
          "purpose_fit",
          "role_clarity",
          "boundary_clarity",
          "sequence_clarity",
          "translation_quality",
          "evidence_alignment",
          "governance_readiness",
          "audience_burden",
          "conflict_risk",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "item": { "type": "string", "minLength": 2 },
          "composition_type": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "purpose_fit": { "type": "number", "minimum": 0, "maximum": 1 },
          "role_clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "boundary_clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "sequence_clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "translation_quality": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_alignment": { "type": "number", "minimum": 0, "maximum": 1 },
          "governance_readiness": { "type": "number", "minimum": 0, "maximum": 1 },
          "audience_burden": { "type": "number", "minimum": 0, "maximum": 1 },
          "conflict_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
