{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/framework-composition-canvas-output.schema.json",
  "title": "Framework Composition Catalyst Canvas Output Schema",
  "description": "Output schema for framework composition audit results, Canvas cards, catalog records, and governance queues.",
  "type": "object",
  "required": ["module", "article_slug", "generated_at", "results", "governance_queue", "canvas_cards"],
  "properties": {
    "module": { "type": "string", "const": "framework_composition_canvas" },
    "article_slug": { "type": "string", "const": "framework-composition-how-to-combine-models-without-confusion" },
    "generated_at": { "type": "string" },
    "results": { "type": "array" },
    "governance_queue": { "type": "array" },
    "canvas_cards": { "type": "array" }
  },
  "additionalProperties": true
}
