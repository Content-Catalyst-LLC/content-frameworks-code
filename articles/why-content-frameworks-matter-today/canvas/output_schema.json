{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/content-framework-value-canvas-output.schema.json",
  "title": "Why Content Frameworks Matter Today Catalyst Canvas Output Schema",
  "description": "Output schema for content framework value audit results, Canvas cards, catalog records, and governance queues.",
  "type": "object",
  "required": ["module", "article_slug", "generated_at", "results", "governance_queue", "canvas_cards"],
  "properties": {
    "module": { "type": "string", "const": "content_framework_value_canvas" },
    "article_slug": { "type": "string", "const": "why-content-frameworks-matter-today" },
    "generated_at": { "type": "string" },
    "results": { "type": "array" },
    "governance_queue": { "type": "array" },
    "canvas_cards": { "type": "array" }
  },
  "additionalProperties": true
}
