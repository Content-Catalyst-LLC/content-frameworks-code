{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/content-framework-value-canvas-input.schema.json",
  "title": "Why Content Frameworks Matter Today Catalyst Canvas Input Schema",
  "description": "Input schema for auditing content framework value including coherence, reuse readiness, evidence visibility, audience pathway clarity, governance maturity, platform readiness, learning support, AI-readiness, fragmentation risk, context preservation, maintenance burden, ownership, and governance status.",
  "type": "object",
  "required": ["module", "article_slug", "items"],
  "properties": {
    "module": { "type": "string", "const": "content_framework_value_canvas" },
    "article_slug": { "type": "string", "const": "why-content-frameworks-matter-today" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "item",
          "framework_type",
          "description",
          "coherence",
          "reuse_readiness",
          "evidence_visibility",
          "audience_pathway_clarity",
          "governance_maturity",
          "platform_readiness",
          "learning_support",
          "ai_readiness",
          "fragmentation_risk",
          "context_preservation",
          "maintenance_burden",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "item": { "type": "string", "minLength": 2 },
          "framework_type": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "coherence": { "type": "number", "minimum": 0, "maximum": 1 },
          "reuse_readiness": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_visibility": { "type": "number", "minimum": 0, "maximum": 1 },
          "audience_pathway_clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "governance_maturity": { "type": "number", "minimum": 0, "maximum": 1 },
          "platform_readiness": { "type": "number", "minimum": 0, "maximum": 1 },
          "learning_support": { "type": "number", "minimum": 0, "maximum": 1 },
          "ai_readiness": { "type": "number", "minimum": 0, "maximum": 1 },
          "fragmentation_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "context_preservation": { "type": "number", "minimum": 0, "maximum": 1 },
          "maintenance_burden": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
