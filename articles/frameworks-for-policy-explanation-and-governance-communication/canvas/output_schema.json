{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/policy-governance-canvas-output.schema.json",
  "title": "Policy Explanation and Governance Communication Catalyst Canvas Output Schema",
  "description": "Output schema for policy explanation audit results Canvas cards catalog records and governance queues.",
  "type": "object",
  "required": ["module", "article_slug", "generated_at", "results", "governance_queue", "canvas_cards"],
  "properties": {
    "module": { "type": "string", "const": "policy_governance_canvas" },
    "article_slug": { "type": "string", "const": "frameworks-for-policy-explanation-and-governance-communication" },
    "generated_at": { "type": "string" },
    "results": { "type": "array" },
    "governance_queue": { "type": "array" },
    "canvas_cards": { "type": "array" }
  },
  "additionalProperties": true
}
