{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/measurement-frameworks-canvas-input.schema.json",
  "title": "OKRs KPIs Measurement Frameworks Catalyst Canvas Input Schema",
  "description": "Input schema for OKR KPI and measurement framework auditing including strategic relevance validity reliability actionability timeliness evidence strength gaming risk reporting burden ambiguity claim strength and governance status.",
  "type": "object",
  "required": ["module", "article_slug", "items"],
  "properties": {
    "module": { "type": "string", "const": "measurement_canvas" },
    "article_slug": { "type": "string", "const": "okrs-kpis-and-measurement-frameworks" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "item",
          "measurement_type",
          "description",
          "strategic_relevance",
          "validity",
          "reliability",
          "actionability",
          "timeliness",
          "evidence_strength",
          "gaming_risk",
          "reporting_burden",
          "ambiguity",
          "claim_strength",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "item": { "type": "string", "minLength": 2 },
          "measurement_type": {
            "type": "string",
            "enum": ["OKR objective", "key result", "KPI", "metric", "threshold", "dashboard item"]
          },
          "description": { "type": "string", "minLength": 5 },
          "strategic_relevance": { "type": "number", "minimum": 0, "maximum": 1 },
          "validity": { "type": "number", "minimum": 0, "maximum": 1 },
          "reliability": { "type": "number", "minimum": 0, "maximum": 1 },
          "actionability": { "type": "number", "minimum": 0, "maximum": 1 },
          "timeliness": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "gaming_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "reporting_burden": { "type": "number", "minimum": 0, "maximum": 1 },
          "ambiguity": { "type": "number", "minimum": 0, "maximum": 1 },
          "claim_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
