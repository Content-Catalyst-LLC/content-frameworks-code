{
  "module": "measurement_canvas",
  "version": "1.0.0",
  "article_slug": "okrs-kpis-and-measurement-frameworks",
  "article_title": "OKRs, KPIs, and Measurement Frameworks",
  "series": "Content Frameworks",
  "repository_path": "articles/okrs-kpis-and-measurement-frameworks/",
  "entrypoint": "python -m measurement_canvas.cli",
  "default_input": "data/measurement_items.csv",
  "input_schema": "canvas/input_schema.json",
  "output_schema": "canvas/output_schema.json",
  "generated_outputs": {
    "audit_table": "outputs/tables/measurement_canvas_audit.csv",
    "catalog": "outputs/json/catalog.json",
    "canvas_cards": "canvas/canvas_cards.json",
    "governance_queue": "canvas/governance_queue.json",
    "governance_markdown": "outputs/markdown/governance_queue.md",
    "full_export": "outputs/json/measurement_canvas_export.json"
  },
  "metrics": [
    "quality_score",
    "measurement_risk",
    "evidence_gap",
    "governance_priority",
    "review_priority"
  ],
  "ui_cards": [
    {
      "type": "measurement_item_card",
      "source": "canvas/canvas_cards.json",
      "recommended_view": "metric_quality_grid"
    },
    {
      "type": "measurement_governance_queue",
      "source": "canvas/governance_queue.json",
      "recommended_view": "review_table"
    }
  ],
  "governance": {
    "owner": "Content Catalyst LLC",
    "review_cycle": "quarterly",
    "status_values": ["active", "review", "revise", "archive"],
    "risk_flags": [
      "evidence_gap",
      "low_validity",
      "low_actionability",
      "high_gaming_risk",
      "high_ambiguity",
      "high_reporting_burden",
      "weak_metric_definition",
      "vanity_metric"
    ]
  }
}
