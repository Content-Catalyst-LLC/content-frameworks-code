{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/swot-analysis-canvas-input.schema.json",
  "title": "SWOT Analysis Catalyst Canvas Input Schema",
  "description": "Input schema for SWOT quadrant orientation priority scoring evidence strength claim strength governance status and review metadata.",
  "type": "object",
  "required": ["module", "article_slug", "items"],
  "properties": {
    "module": { "type": "string", "const": "swot_canvas" },
    "article_slug": { "type": "string", "const": "swot-analysis-strengths-uses-and-limits" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "item",
          "quadrant",
          "orientation",
          "description",
          "impact",
          "confidence",
          "urgency",
          "feasibility",
          "strategic_fit",
          "evidence_strength",
          "claim_strength",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "item": { "type": "string", "minLength": 2 },
          "quadrant": { "type": "string", "enum": ["strength", "weakness", "opportunity", "threat"] },
          "orientation": { "type": "string", "enum": ["internal", "external"] },
          "description": { "type": "string", "minLength": 5 },
          "impact": { "type": "number", "minimum": 0, "maximum": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "urgency": { "type": "number", "minimum": 0, "maximum": 1 },
          "feasibility": { "type": "number", "minimum": 0, "maximum": 1 },
          "strategic_fit": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "claim_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
