{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/swot-analysis-canvas-output.schema.json",
  "title": "SWOT Analysis Catalyst Canvas Output Schema",
  "description": "Output schema for SWOT priority audit results UI cards catalog records TOWS candidates and governance queues.",
  "type": "object",
  "required": ["module", "article_slug", "generated_at", "results", "governance_queue", "canvas_cards"],
  "properties": {
    "module": { "type": "string", "const": "swot_canvas" },
    "article_slug": { "type": "string", "const": "swot-analysis-strengths-uses-and-limits" },
    "generated_at": { "type": "string" },
    "results": { "type": "array" },
    "governance_queue": { "type": "array" },
    "canvas_cards": { "type": "array" }
  },
  "additionalProperties": true
}
