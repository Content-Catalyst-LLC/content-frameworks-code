{
  "module": "swot_canvas",
  "version": "1.0.0",
  "article_slug": "swot-analysis-strengths-uses-and-limits",
  "article_title": "SWOT Analysis: Strengths, Uses, and Limits",
  "series": "Content Frameworks",
  "repository_path": "articles/swot-analysis-strengths-uses-and-limits/",
  "entrypoint": "python -m swot_canvas.cli",
  "default_input": "data/swot_items.csv",
  "input_schema": "canvas/input_schema.json",
  "output_schema": "canvas/output_schema.json",
  "generated_outputs": {
    "audit_table": "outputs/tables/swot_canvas_audit.csv",
    "catalog": "outputs/json/catalog.json",
    "canvas_cards": "canvas/canvas_cards.json",
    "governance_queue": "canvas/governance_queue.json",
    "governance_markdown": "outputs/markdown/governance_queue.md",
    "full_export": "outputs/json/swot_canvas_export.json"
  },
  "metrics": [
    "priority_score",
    "weighted_priority",
    "evidence_gap",
    "governance_priority",
    "review_priority"
  ],
  "ui_cards": [
    {
      "type": "swot_item_card",
      "source": "canvas/canvas_cards.json",
      "recommended_view": "quadrant_grid"
    },
    {
      "type": "swot_governance_queue",
      "source": "canvas/governance_queue.json",
      "recommended_view": "review_table"
    }
  ],
  "governance": {
    "owner": "Content Catalyst LLC",
    "review_cycle": "quarterly",
    "status_values": ["active", "review", "revise", "archive"],
    "risk_flags": ["evidence_gap", "weak_specificity", "quadrant_confusion", "low_confidence", "action_gap"]
  }
}
