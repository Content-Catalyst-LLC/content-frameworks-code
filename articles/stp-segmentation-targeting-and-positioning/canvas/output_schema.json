{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/stp-canvas-output.schema.json",
  "title": "STP Catalyst Canvas Output Schema",
  "description": "Output schema for Catalyst Canvas STP audit results, UI cards, catalog records, and governance queues.",
  "type": "object",
  "required": ["module", "article_slug", "generated_at", "results", "governance_queue", "canvas_cards"],
  "properties": {
    "module": { "type": "string", "const": "stp_canvas" },
    "article_slug": { "type": "string", "const": "stp-segmentation-targeting-and-positioning" },
    "generated_at": { "type": "string" },
    "results": { "type": "array" },
    "governance_queue": { "type": "array" },
    "canvas_cards": { "type": "array" }
  },
  "additionalProperties": true
}
