{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/stp-canvas-input.schema.json",
  "title": "STP Catalyst Canvas Input Schema",
  "description": "Input schema for segmentation, targeting, positioning, evidence-fit, and ethical-review records used by the STP Catalyst Canvas module.",
  "type": "object",
  "required": ["module", "article_slug", "segments"],
  "properties": {
    "module": {
      "type": "string",
      "const": "stp_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "stp-segmentation-targeting-and-positioning"
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "segment",
          "description",
          "primary_job",
          "content_pathway",
          "need_intensity",
          "strategic_fit",
          "reachability",
          "evidence_fit",
          "ethical_responsibility",
          "category_clarity",
          "audience_relevance",
          "differentiation",
          "credibility",
          "stereotype_risk",
          "exclusion_risk",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "segment": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "primary_job": { "type": "string", "minLength": 5 },
          "content_pathway": { "type": "string", "minLength": 3 },
          "need_intensity": { "type": "number", "minimum": 0, "maximum": 1 },
          "strategic_fit": { "type": "number", "minimum": 0, "maximum": 1 },
          "reachability": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_fit": { "type": "number", "minimum": 0, "maximum": 1 },
          "ethical_responsibility": { "type": "number", "minimum": 0, "maximum": 1 },
          "category_clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "audience_relevance": { "type": "number", "minimum": 0, "maximum": 1 },
          "differentiation": { "type": "number", "minimum": 0, "maximum": 1 },
          "credibility": { "type": "number", "minimum": 0, "maximum": 1 },
          "stereotype_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "exclusion_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
