{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/stp-segmentation-targeting-and-positioning-canvas-input.schema.json",
  "title": "Catalyst Canvas Input Schema: STP: Segmentation, Targeting, and Positioning",
  "description": "Input schema for Catalyst Canvas article-readiness records.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "records"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "stp_segmentation_targeting_and_positioning_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "stp-segmentation-targeting-and-positioning"
    },
    "records": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
