{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/hierarchy-of-effects-and-communication-response-models-canvas-output.schema.json",
  "title": "Catalyst Canvas Output Schema: Hierarchy of Effects and Communication Response Models",
  "description": "Output schema for Catalyst Canvas article-readiness audit results, UI cards, catalog records, and governance queues.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "generated_at",
    "results",
    "governance_queue",
    "canvas_cards"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "hierarchy_of_effects_and_communication_response_models_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "hierarchy-of-effects-and-communication-response-models"
    },
    "generated_at": {
      "type": "string"
    },
    "results": {
      "type": "array"
    },
    "governance_queue": {
      "type": "array"
    },
    "canvas_cards": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
