{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/hierarchy-of-effects-and-communication-response-models-canvas-input.schema.json",
  "title": "Catalyst Canvas Input Schema: Hierarchy of Effects and Communication Response Models",
  "description": "Input schema for Catalyst Canvas article-readiness records.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "records"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "hierarchy_of_effects_and_communication_response_models_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "hierarchy-of-effects-and-communication-response-models"
    },
    "records": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
