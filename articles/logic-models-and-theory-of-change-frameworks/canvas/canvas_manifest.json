{
  "module": "logic_model_canvas",
  "version": "1.0.0",
  "article_slug": "logic-models-and-theory-of-change-frameworks",
  "article_title": "Logic Models and Theory of Change Frameworks",
  "series": "Content Frameworks",
  "repository_path": "articles/logic-models-and-theory-of-change-frameworks/",
  "entrypoint": "python -m logic_model_canvas.cli",
  "default_input": "data/logic_model_elements.csv",
  "input_schema": "canvas/input_schema.json",
  "output_schema": "canvas/output_schema.json",
  "generated_outputs": {
    "audit_table": "outputs/tables/logic_model_canvas_audit.csv",
    "catalog": "outputs/json/catalog.json",
    "canvas_cards": "canvas/canvas_cards.json",
    "governance_queue": "canvas/governance_queue.json",
    "governance_markdown": "outputs/markdown/governance_queue.md",
    "full_export": "outputs/json/logic_model_canvas_export.json"
  },
  "metrics": [
    "assumption_risk",
    "evidence_gap",
    "pathway_quality",
    "governance_priority",
    "review_priority"
  ],
  "ui_cards": [
    {
      "type": "logic_model_element_card",
      "source": "canvas/canvas_cards.json",
      "recommended_view": "causal_pathway_grid"
    },
    {
      "type": "logic_model_governance_queue",
      "source": "canvas/governance_queue.json",
      "recommended_view": "review_table"
    }
  ],
  "governance": {
    "owner": "Content Catalyst LLC",
    "review_cycle": "quarterly",
    "status_values": [
      "active",
      "review",
      "revise",
      "archive"
    ],
    "risk_flags": [
      "evidence_gap",
      "high_assumption_risk",
      "weak_assumption_evidence",
      "weak_measurement_coverage",
      "unclear_outcome",
      "unsupported_impact_claim",
      "causal_overclaim"
    ]
  }
}
