{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/educational-scaffolding-and-the-design-of-learning-systems-canvas-input.schema.json",
  "title": "Catalyst Canvas Input Schema: Educational Scaffolding and the Design of Learning Systems",
  "description": "Input schema for Catalyst Canvas article-readiness records.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "records"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "educational_scaffolding_and_the_design_of_learning_systems_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "educational-scaffolding-and-the-design-of-learning-systems"
    },
    "records": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
