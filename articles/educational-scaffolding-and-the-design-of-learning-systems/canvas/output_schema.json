{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/educational-scaffolding-and-the-design-of-learning-systems-canvas-output.schema.json",
  "title": "Catalyst Canvas Output Schema: Educational Scaffolding and the Design of Learning Systems",
  "description": "Output schema for Catalyst Canvas article-readiness audit results, UI cards, catalog records, and governance queues.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "generated_at",
    "results",
    "governance_queue",
    "canvas_cards"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "educational_scaffolding_and_the_design_of_learning_systems_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "educational-scaffolding-and-the-design-of-learning-systems"
    },
    "generated_at": {
      "type": "string"
    },
    "results": {
      "type": "array"
    },
    "governance_queue": {
      "type": "array"
    },
    "canvas_cards": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
