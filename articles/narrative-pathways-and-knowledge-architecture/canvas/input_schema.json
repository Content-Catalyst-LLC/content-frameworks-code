{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/narrative-pathways-and-knowledge-architecture-canvas-input.schema.json",
  "title": "Catalyst Canvas Input Schema: Narrative Pathways and Knowledge Architecture",
  "description": "Input schema for Catalyst Canvas article-readiness records.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "records"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "narrative_pathways_and_knowledge_architecture_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "narrative-pathways-and-knowledge-architecture"
    },
    "records": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
