{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/interdisciplinary-frameworks-and-knowledge-bridges-canvas-input.schema.json",
  "title": "Catalyst Canvas Input Schema: Interdisciplinary Frameworks and Knowledge Bridges",
  "description": "Input schema for Catalyst Canvas article-readiness records.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "records"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "interdisciplinary_frameworks_and_knowledge_bridges_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "interdisciplinary-frameworks-and-knowledge-bridges"
    },
    "records": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
