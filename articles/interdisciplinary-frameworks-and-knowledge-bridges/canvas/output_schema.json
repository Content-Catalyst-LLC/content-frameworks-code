{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/interdisciplinary-frameworks-and-knowledge-bridges-canvas-output.schema.json",
  "title": "Catalyst Canvas Output Schema: Interdisciplinary Frameworks and Knowledge Bridges",
  "description": "Output schema for Catalyst Canvas article-readiness audit results, UI cards, catalog records, and governance queues.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "generated_at",
    "results",
    "governance_queue",
    "canvas_cards"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "interdisciplinary_frameworks_and_knowledge_bridges_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "interdisciplinary-frameworks-and-knowledge-bridges"
    },
    "generated_at": {
      "type": "string"
    },
    "results": {
      "type": "array"
    },
    "governance_queue": {
      "type": "array"
    },
    "canvas_cards": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
