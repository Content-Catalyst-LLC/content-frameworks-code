{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/framework-governance-canvas-input.schema.json",
  "title": "Framework Governance and Editorial Maintenance Catalyst Canvas Input Schema",
  "description": "Input schema for auditing framework governance and editorial maintenance including ownership clarity, review-cycle strength, metadata completeness, evidence status, link health, taxonomy alignment, platform readiness, stale evidence risk, dependency complexity, audience impact, ownership, and governance status.",
  "type": "object",
  "required": ["module", "article_slug", "items"],
  "properties": {
    "module": { "type": "string", "const": "framework_governance_canvas" },
    "article_slug": { "type": "string", "const": "framework-governance-and-editorial-maintenance" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "item",
          "item_type",
          "description",
          "ownership_clarity",
          "review_cycle_strength",
          "metadata_completeness",
          "evidence_status",
          "link_health",
          "taxonomy_alignment",
          "platform_readiness",
          "stale_evidence_risk",
          "dependency_complexity",
          "audience_impact",
          "owner",
          "status",
          "review_date"
        ],
        "properties": {
          "item": { "type": "string", "minLength": 2 },
          "item_type": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 5 },
          "ownership_clarity": { "type": "number", "minimum": 0, "maximum": 1 },
          "review_cycle_strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "metadata_completeness": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_status": { "type": "number", "minimum": 0, "maximum": 1 },
          "link_health": { "type": "number", "minimum": 0, "maximum": 1 },
          "taxonomy_alignment": { "type": "number", "minimum": 0, "maximum": 1 },
          "platform_readiness": { "type": "number", "minimum": 0, "maximum": 1 },
          "stale_evidence_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "dependency_complexity": { "type": "number", "minimum": 0, "maximum": 1 },
          "audience_impact": { "type": "number", "minimum": 0, "maximum": 1 },
          "owner": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["active", "review", "revise", "archive"] },
          "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
