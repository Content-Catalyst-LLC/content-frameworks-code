{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecontentcatalyst.net/schemas/aida-and-the-logic-of-persuasive-sequence-canvas-output.schema.json",
  "title": "Catalyst Canvas Output Schema: AIDA and the Logic of Persuasive Sequence",
  "description": "Output schema for Catalyst Canvas article-readiness audit results, UI cards, catalog records, and governance queues.",
  "type": "object",
  "required": [
    "module",
    "article_slug",
    "generated_at",
    "results",
    "governance_queue",
    "canvas_cards"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "aida_and_the_logic_of_persuasive_sequence_canvas"
    },
    "article_slug": {
      "type": "string",
      "const": "aida-and-the-logic-of-persuasive-sequence"
    },
    "generated_at": {
      "type": "string"
    },
    "results": {
      "type": "array"
    },
    "governance_queue": {
      "type": "array"
    },
    "canvas_cards": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
