{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Framework Quality Record",
  "type": "object",
  "required": [
    "framework_id",
    "framework_name",
    "domain",
    "primary_use",
    "clarity",
    "coherence",
    "transferability",
    "adaptability",
    "explanatory_depth",
    "domain_fit",
    "audience_fit",
    "evidence_alignment",
    "ethical_safety",
    "governability"
  ],
  "properties": {
    "framework_id": { "type": "string" },
    "framework_name": { "type": "string" },
    "domain": { "type": "string" },
    "primary_use": { "type": "string" },
    "clarity": { "type": "integer", "minimum": 1, "maximum": 5 },
    "coherence": { "type": "integer", "minimum": 1, "maximum": 5 },
    "transferability": { "type": "integer", "minimum": 1, "maximum": 5 },
    "adaptability": { "type": "integer", "minimum": 1, "maximum": 5 },
    "explanatory_depth": { "type": "integer", "minimum": 1, "maximum": 5 },
    "domain_fit": { "type": "integer", "minimum": 1, "maximum": 5 },
    "audience_fit": { "type": "integer", "minimum": 1, "maximum": 5 },
    "evidence_alignment": { "type": "integer", "minimum": 1, "maximum": 5 },
    "ethical_safety": { "type": "integer", "minimum": 1, "maximum": 5 },
    "governability": { "type": "integer", "minimum": 1, "maximum": 5 },
    "risk_severity": { "type": "string" },
    "risk_note": { "type": "string" }
  }
}
