{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Content Framework Value Record",
  "type": "object",
  "required": [
    "framework_id",
    "framework_name",
    "domain",
    "primary_use",
    "comprehension",
    "comparison",
    "retention",
    "action",
    "governance",
    "evidence_integrity",
    "audience_fit",
    "ethical_safety"
  ],
  "properties": {
    "framework_id": { "type": "string" },
    "framework_name": { "type": "string" },
    "domain": { "type": "string" },
    "primary_use": { "type": "string" },
    "comprehension": { "type": "integer", "minimum": 1, "maximum": 5 },
    "comparison": { "type": "integer", "minimum": 1, "maximum": 5 },
    "retention": { "type": "integer", "minimum": 1, "maximum": 5 },
    "action": { "type": "integer", "minimum": 1, "maximum": 5 },
    "governance": { "type": "integer", "minimum": 1, "maximum": 5 },
    "evidence_integrity": { "type": "integer", "minimum": 1, "maximum": 5 },
    "audience_fit": { "type": "integer", "minimum": 1, "maximum": 5 },
    "ethical_safety": { "type": "integer", "minimum": 1, "maximum": 5 },
    "risk_severity": { "type": "string" },
    "risk_if_misused": { "type": "string" }
  }
}
